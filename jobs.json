  {
  "id": "dag-test-001",
  "name": "Dependency Test Job",
  "schedule": "*/5 * * * *",
  "description": "Tests dependency-based execution.",
  "MAX_CONCURRENCY": 2,
  "STEPS": [
    {
      "ORDER": 1,
      "ID": "fetch-cat-fact",
      "NAME": "Fetch cat fact",
      "TYPE": "RESTAPI",
      "STEP_PARAMS": {
        "URL": "https://catfact.ninja/fact",
        "METHOD": "GET",
        "TIMEOUT_MS": 10000
      }
    },
    {
      "ORDER": 2,
      "ID": "fetch-random-user",
      "NAME": "Fetch random user",
      "TYPE": "RESTAPI",
      "STEP_PARAMS": {
        "URL": "https://randomuser.me/api/?results=1",
        "METHOD": "GET"
      }
    },
    {
      "ORDER": 3,
      "ID": "parse-cat-fact",
      "NAME": "Parse cat fact",
      "TYPE": "SCRIPT",
      "DEPENDS_ON": ["fetch-cat-fact"],
      "STEP_PARAMS": {
        "CODE": "((context) => { const response = context['fetch-cat-fact']; return { fact: response.data.fact, length: response.data.length }; })"
      }
    },
    {
      "ORDER": 4,
      "ID": "parse-random-user",
      "NAME": "Parse random user",
      "TYPE": "SCRIPT",
      "DEPENDS_ON": ["fetch-random-user"],
      "STEP_PARAMS": {
        "CODE": "((context) => { const response = context['fetch-random-user']; const user = response.data.results[0]; return { fullName: `${user.name.first} ${user.name.last}`, email: user.email }; })"
      }
    },
    {
      "ORDER": 5,
      "ID": "combine-results",
      "NAME": "Combine results",
      "TYPE": "SCRIPT",
      "DEPENDS_ON": ["parse-cat-fact", "parse-random-user"],
      "STEP_PARAMS": {
        "CODE": "((context) => { return { catFact: context['parse-cat-fact'].fact, user: context['parse-random-user'].fullName }; })"
      }
    }
  ],
  "status": "active",
  "last_run": null,
  "next_run": null
  },
