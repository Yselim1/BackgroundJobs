 {
   "id": "rest-enhanced-post-context",
   "name": "REST POST Context Test",
   "schedule": "0 0 1 1 *",
   "description": "Loads a post, then uses its response in a POST query, header, and JSON body.",
   "MAX_CONCURRENCY": 1,
   "STEPS": [
     {
       "ORDER": 1,
       "ID": "load-source-post",
       "NAME": "Load source post",
       "TYPE": "RESTAPI",
       "STEP_PARAMS": {
         "URL": "https://jsonplaceholder.typicode.com/posts/1",
         "METHOD": "GET",
         "RESPONSE_TYPE": "json",
         "CAPTURE_RESPONSE_HEADERS": ["content-type"],
         "TIMEOUT_MS": 10000
       }
     },
     {
       "ORDER": 2,
       "ID": "create-derived-post",
       "NAME": "Create derived post",
       "TYPE": "RESTAPI",
       "DEPENDS_ON": ["load-source-post"],
       "STEP_PARAMS": {
         "URL": "https://jsonplaceholder.typicode.com/posts",
         "METHOD": "POST",
         "HEADERS": {
           "X-Source-Post-Id": "{{load-source-post.data.id}}"
         },
         "QUERY": {
           "copiedFrom": "{{load-source-post.data.id}}"
         },
         "BODY": {
