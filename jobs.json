[
 {
    "id": "cron-001",
    "name": "Fetch Daily Cat Fact",
    "schedule": "0 9 * * *",
    "description": "Makes REST API call to fetch a random fact, then uses a script to parse the response.",
    "STEPS": [
      {
        "ORDER": 1,
        "NAME": "FETCH_API",
        "TYPE": "RESTAPI",
        "STEP_PARAMS": {
          "URL": "https://catfact.ninja/fact",
          "METHOD": "GET"
        }
      },
      {
        "ORDER": 2,
        "NAME": "FETCH_API_2",
        "TYPE": "RESTAPI",
        "STEP_PARAMS": {
          "URL": "https://randomuser.me/api/?results=1",
          "METHOD": "GET"
        }
      },
      {
        "ORDER": 3,
        "NAME": "PARSE_RESULT",
        "TYPE": "SCRIPT",
        "DEPENDS_ON": ["FETCH_API"],
        "STEP_PARAMS": {
          "CODE": "((context) => { const apiResponse = context.FETCH_API; return { statusCheck: apiResponse.status === 200 ? 'OK' : 'FAIL', factText: apiResponse.data.fact, factLength: apiResponse.data.length }; })"
        }
      }
    ],
    "status": "active",
    "last_run": null,
    "next_run": "2026-06-28T09:00:00Z"
 },
 {
    "id": "cron-002",
    "name": "User Data Sync Pipeline",
    "schedule": "0 * * * *",
    "description": "Fetches random user data, transforms it using a script, and simulates a final system command.",
    "STEPS": [
      {
        "ORDER": 1,
        "NAME": "FETCH_USERS",
        "TYPE": "RESTAPI",
        "STEP_PARAMS": {
          "URL": "https://randomuser.me/api/?results=1",
          "METHOD": "GET"
        }
      },
      {
        "ORDER": 2,
        "NAME": "TRANSFORM_DATA",
        "TYPE": "SCRIPT",
        "STEP_PARAMS": {
          "CODE": "((context) => { const users = context.FETCH_USERS.data.results; return users.map(u => ({ fullName: u.name.first + ' ' + u.name.last, email: u.email })); })"
        }
      },
      {
        "ORDER": 3,
        "NAME": "FINALIZE_SYNC",
        "TYPE": "COMMAND",
        "STEP_PARAMS": {
          "COMMAND": "echo 'a user successfully synced to the data warehouse'"
        }
      }
    ],
    "status": "active",
    "last_run": null,
    "next_run": "2026-06-27T15:00:00Z"
 },
 {
    "id": "cron-003",
    "name": "Python Data Processing",
    "schedule": "0 12 * * *",
    "description": "Runs a Python script to do math/data processing and returns JSON.",
    "STEPS": [
      {
        "ORDER": 1,
        "NAME": "MATH_OPERATION",
        "TYPE": "PYTHON",
        "STEP_PARAMS": {
          "CODE": "import json\nimport math\n\nresult = {\n  'status': 'success',\n  'pi_value': math.pi,\n  'calculation': math.sqrt(144)\n}\n\nprint(json.dumps(result))"
        }
      }
    ],
    "status": "active",
    "last_run": null,
    "next_run": "2026-06-28T12:00:00Z"
 },
