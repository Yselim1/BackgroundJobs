 {
  "id": "test-eventual-retry-success",
  "name": "Eventual Retry Success Test",
  "schedule": "*/5 * * * *",
  "MAX_CONCURRENCY": 1,
  "FAILURE_POLICY": "fail_fast",
  "DEFAULT_STEP_RETRY": {
    "MAX_ATTEMPTS": 5,
    "DELAY_MS": 200,
    "BACKOFF": "fixed"
  },
  "STEPS": [
    {
      "ORDER": 1,
      "ID": "eventual-success-command",
      "NAME": "Command succeeds on third attempt",
      "TYPE": "COMMAND",
      "STEP_PARAMS": {
        "COMMAND": "node -e \"const fs=require('fs');const p='.retry-test-eventual-success';let count=fs.existsSync(p)?Number(fs.readFileSync(p,'utf8')):0;count++;if(count<3){fs.writeFileSync(p,String(count));process.exit(1);}if(fs.existsSync(p))fs.unlinkSync(p);console.log('Succeeded on attempt '+count);\""
      }
    },
    {
      "ORDER": 2,
      "ID": "after-eventual-success",
      "NAME": "Runs after retry succeeds",
      "TYPE": "COMMAND",
      "DEPENDS_ON": [
        "eventual-success-command"
      ],
      "STEP_PARAMS": {
        "COMMAND": "node -e \"console.log('Dependency succeeded')\""
      }
    }
  ],
  "status": "active"
 },
